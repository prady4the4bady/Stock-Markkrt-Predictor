# ── NexusTrader Production Environment Variables ──────────────────────────

# ── Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=CHANGE_ME_generate_a_secure_random_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database (PostgreSQL on Supabase / Render / Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── PayPal (get from developer.paypal.com)
# Set PAYPAL_MODE=sandbox for testing, live for real payments
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ── Frontend URL (used for PayPal redirect URLs)
FRONTEND_URL=https://your-domain.com

# ── CORS (comma-separated list of allowed origins)
CORS_ORIGINS=https://your-domain.com

# ── Server
API_HOST=0.0.0.0
API_PORT=8000
PYTHONIOENCODING=utf-8
PYTHONUTF8=1
