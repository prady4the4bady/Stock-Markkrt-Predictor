# =============================================================================
# NexusTrader — Environment Variables
# Copy this file to .env and fill in your values
# All REQUIRED items must be set before deployment
# =============================================================================

# ── NVIDIA NIM (Model Council + Kimi Analyst) ─────────────────────────────────
# Get free API key at: https://build.nvidia.com/
# Free tier: 1,000 API calls/month per model (12 models in council)
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE

# ── Security (REQUIRED — use a long random string) ────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL (production) — leave commented for local SQLite
# Get from: https://supabase.com → Project Settings → Database → Connection String
# Use the "Transaction pooler" URL (port 6543) for Render
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# ── Supabase (optional — only needed for Row Level Security features) ─────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Frontend / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.onrender.com
CORS_ORIGINS=https://your-app.onrender.com,http://localhost:5173

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── PayPal (optional — payments quarantined for now) ─────────────────────────
# Get from: https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox

# ── Additional free data sources (optional — improve predictions) ──────────────
# Alpha Vantage — extra fundamental data
# Free: https://www.alphavantage.co/support/#api-key (500 req/day)
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_KEY

# FRED (Federal Reserve Economic Data) — macro indicators, bond yields
# Free: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_API_KEY

# NewsAPI — headlines sentiment
# Free tier: https://newsapi.org/ (100 req/day developer, 500 production)
NEWS_API_KEY=YOUR_NEWS_API_KEY

# CoinGecko — crypto listings & market data
# Free tier (no key required), Pro key removes rate limits
# https://www.coingecko.com/en/api
COINGECKO_API_KEY=CG-YOUR_KEY_HERE

# =============================================================================
# Render deployment checklist:
# 1. Set JWT_SECRET_KEY (permanent, not ephemeral)
# 2. Set NVIDIA_API_KEY
# 3. Set DATABASE_URL (Supabase transaction pooler)
# 4. Set FRONTEND_URL and CORS_ORIGINS
# =============================================================================
